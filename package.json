{
  "name": "whisper-subtitle-flow",
  "displayName": "Whisper Subtitle Flow",
  "description": "Batch subtitle generation & translation with Whisper + LLM",
  "version": "0.0.4",
  "publisher": "wedaren",
  "repository": {
    "type": "git",
    "url": "https://github.com/wedaren/whisperBatcher.git"
  },
  "homepage": "https://github.com/wedaren/whisperBatcher",
  "bugs": {
    "url": "https://github.com/wedaren/whisperBatcher/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:wedaren.whisper-subtitle-flow.agent",
    "onLanguageModelTool:subtitleflow_list_tasks",
    "onLanguageModelTool:subtitleflow_list_batches",
    "onLanguageModelTool:subtitleflow_get_latest_batch",
    "onLanguageModelTool:subtitleflow_get_task",
    "onLanguageModelTool:subtitleflow_summarize_task_result",
    "onLanguageModelTool:subtitleflow_enqueue_task",
    "onLanguageModelTool:subtitleflow_enqueue_tasks",
    "onLanguageModelTool:subtitleflow_scan_directory",
    "onLanguageModelTool:subtitleflow_run_pending",
    "onLanguageModelTool:subtitleflow_pause_task",
    "onLanguageModelTool:subtitleflow_resume_task",
    "onLanguageModelTool:subtitleflow_retry_task",
    "onLanguageModelTool:subtitleflow_delete_task"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "subtitleFlow",
          "title": "Subtitle Flow",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "subtitleFlow": [
        {
          "id": "subtitleFlowTasks",
          "name": "Tasks",
          "type": "tree",
          "icon": "$(list-unordered)"
        }
      ]
    },
    "commands": [
      {
        "command": "subtitleFlow.agent",
        "title": "Open Subtitle Flow Agent",
        "category": "Subtitle Flow",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "subtitleFlow.addVideos",
        "title": "Add Videos",
        "category": "Subtitle Flow",
        "icon": "$(add)"
      },
      {
        "command": "subtitleFlow.runPending",
        "title": "Run Pending Tasks",
        "category": "Subtitle Flow",
        "icon": "$(run-all)"
      },
      {
        "command": "subtitleFlow.showTaskList",
        "title": "Show Task List",
        "category": "Subtitle Flow",
        "icon": "$(list-unordered)"
      },
      {
        "command": "subtitleFlow.showTaskBatches",
        "title": "Show Task Batches",
        "category": "Subtitle Flow",
        "icon": "$(group-by-ref-type)"
      },
      {
        "command": "subtitleFlow.pauseResumeTask",
        "title": "Pause / Resume Task",
        "category": "Subtitle Flow",
        "icon": "$(debug-pause)"
      },
      {
        "command": "subtitleFlow.retryTask",
        "title": "Retry Failed Task",
        "category": "Subtitle Flow",
        "icon": "$(refresh)"
      },
      {
        "command": "subtitleFlow.rebuildFromTranscribe",
        "title": "Rebuild From Transcribe",
        "category": "Subtitle Flow",
        "icon": "$(debug-restart)"
      },
      {
        "command": "subtitleFlow.rebuildFromOptimize",
        "title": "Rebuild From Optimize",
        "category": "Subtitle Flow",
        "icon": "$(refresh)"
      },
      {
        "command": "subtitleFlow.rebuildFromTranslate",
        "title": "Rebuild From Translate",
        "category": "Subtitle Flow",
        "icon": "$(globe)"
      },
      {
        "command": "subtitleFlow.revealInOS",
        "title": "Reveal in OS File Manager",
        "category": "Subtitle Flow",
        "icon": "$(folder-opened)"
      },
      {
        "command": "subtitleFlow.clearStaleTasks",
        "title": "Clear Stale Tasks",
        "category": "Subtitle Flow",
        "icon": "$(trash)"
      },
      {
        "command": "subtitleFlow.migrateArtifactLayout",
        "title": "Migrate Artifact Layout",
        "category": "Subtitle Flow",
        "icon": "$(folder-library)"
      },
      {
        "command": "subtitleFlow.deleteTask",
        "title": "Delete Task",
        "category": "Subtitle Flow",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "subtitleFlow.agent",
          "when": "view == subtitleFlowTasks",
          "group": "navigation@0"
        },
        {
          "command": "subtitleFlow.addVideos",
          "when": "view == subtitleFlowTasks",
          "group": "navigation@1"
        },
        {
          "command": "subtitleFlow.runPending",
          "when": "view == subtitleFlowTasks",
          "group": "navigation@2"
        },
        {
          "command": "subtitleFlow.clearStaleTasks",
          "when": "view == subtitleFlowTasks",
          "group": "navigation@3"
        },
        {
          "command": "subtitleFlow.migrateArtifactLayout",
          "when": "view == subtitleFlowTasks",
          "group": "navigation@3"
        },
        {
          "command": "subtitleFlow.showTaskList",
          "when": "view == subtitleFlowTasks && subtitleFlow.viewMode != list",
          "group": "navigation@4"
        },
        {
          "command": "subtitleFlow.showTaskBatches",
          "when": "view == subtitleFlowTasks && subtitleFlow.viewMode != batch",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "subtitleFlow.pauseResumeTask",
          "when": "view == subtitleFlowTasks && viewItem == task",
          "group": "inline@1"
        },
        {
          "command": "subtitleFlow.retryTask",
          "when": "view == subtitleFlowTasks && viewItem == taskFailed",
          "group": "inline@1"
        },
        {
          "command": "subtitleFlow.revealInOS",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "context@1"
        },
        {
          "command": "subtitleFlow.rebuildFromTranscribe",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "context@2"
        },
        {
          "command": "subtitleFlow.rebuildFromOptimize",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "context@2"
        },
        {
          "command": "subtitleFlow.rebuildFromTranslate",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "context@2"
        },
        {
          "command": "subtitleFlow.migrateArtifactLayout",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "context@3"
        },
        {
          "command": "subtitleFlow.deleteTask",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "inline@3"
        },
        {
          "command": "subtitleFlow.deleteTask",
          "when": "view == subtitleFlowTasks && viewItem =~ /^task/",
          "group": "context@3"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "wedaren.whisper-subtitle-flow.agent",
        "name": "subtitleFlow",
        "fullName": "Subtitle Flow Agent",
        "description": "Manage subtitle background jobs for long-running Whisper and LLM workflows.",
        "isSticky": true,
        "commands": [
          {
            "name": "help",
            "description": "Show subtitle agent usage"
          },
          {
            "name": "list",
            "description": "List subtitle tasks"
          },
          {
            "name": "batches",
            "description": "List recent subtitle batches"
          },
          {
            "name": "enqueue",
            "description": "Create a queued subtitle task from a video path"
          },
          {
            "name": "run",
            "description": "Start the pending queue or create and start a task"
          },
          {
            "name": "get",
            "description": "Inspect one subtitle task"
          },
          {
            "name": "result",
            "description": "Summarize one subtitle task result"
          },
          {
            "name": "pause",
            "description": "Pause a running subtitle task"
          },
          {
            "name": "resume",
            "description": "Resume a paused subtitle task"
          },
          {
            "name": "retry",
            "description": "Retry a failed subtitle task"
          },
          {
            "name": "delete",
            "description": "Delete a subtitle task record"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "subtitleflow_list_tasks",
        "displayName": "List Subtitle Tasks",
        "modelDescription": "List subtitle workflow tasks with status and outputs.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        },
        "tags": [
          "subtitle",
          "tasks",
          "read"
        ]
      },
      {
        "name": "subtitleflow_list_batches",
        "displayName": "List Subtitle Batches",
        "modelDescription": "List recent subtitle task batches with aggregated progress counters.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        },
        "tags": [
          "subtitle",
          "tasks",
          "read",
          "batch"
        ]
      },
      {
        "name": "subtitleflow_get_latest_batch",
        "displayName": "Get Latest Subtitle Batch",
        "modelDescription": "Read the latest subtitle task batch summary.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        },
        "tags": [
          "subtitle",
          "tasks",
          "read",
          "batch"
        ]
      },
      {
        "name": "subtitleflow_get_task",
        "displayName": "Get Subtitle Task",
        "modelDescription": "Get a subtitle task by task id.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": [
            "taskId"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "read"
        ]
      },
      {
        "name": "subtitleflow_summarize_task_result",
        "displayName": "Summarize Subtitle Result",
        "modelDescription": "Summarize output files and review artifacts for one subtitle task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": [
            "taskId"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "read",
          "result"
        ]
      },
      {
        "name": "subtitleflow_enqueue_task",
        "displayName": "Enqueue Subtitle Task",
        "modelDescription": "Create a queued subtitle generation task for an absolute video path.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "videoPath": {
              "type": "string"
            },
            "whisperModel": {
              "type": "string"
            },
            "whisperLanguage": {
              "type": "string"
            },
            "targetLanguages": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "defaultSubtitleLanguage": {
              "type": "string"
            },
            "generateBilingualAss": {
              "type": "boolean"
            },
            "bilingualTargetLanguage": {
              "type": "string"
            }
          },
          "required": [
            "videoPath"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "write"
        ]
      },
      {
        "name": "subtitleflow_enqueue_tasks",
        "displayName": "Enqueue Subtitle Tasks",
        "modelDescription": "Create queued subtitle generation tasks for multiple absolute video paths.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "inputs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "videoPath": {
                    "type": "string"
                  }
                },
                "required": [
                  "videoPath"
                ]
              }
            },
            "whisperModel": {
              "type": "string"
            },
            "whisperLanguage": {
              "type": "string"
            },
            "targetLanguages": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "defaultSubtitleLanguage": {
              "type": "string"
            },
            "generateBilingualAss": {
              "type": "boolean"
            },
            "bilingualTargetLanguage": {
              "type": "string"
            }
          },
          "required": [
            "inputs"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "write",
          "batch"
        ]
      },
      {
        "name": "subtitleflow_scan_directory",
        "displayName": "Scan Subtitle Directory",
        "modelDescription": "Scan a directory and return video files that can be enqueued for subtitle generation.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "directoryPath": {
              "type": "string"
            },
            "recursive": {
              "type": "boolean"
            },
            "maxFiles": {
              "type": "number"
            }
          },
          "required": [
            "directoryPath"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "read",
          "filesystem"
        ]
      },
      {
        "name": "subtitleflow_run_pending",
        "displayName": "Run Pending Subtitle Tasks",
        "modelDescription": "Ask the background scheduler to start queued subtitle tasks.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        },
        "tags": [
          "subtitle",
          "tasks",
          "write"
        ]
      },
      {
        "name": "subtitleflow_pause_task",
        "displayName": "Pause Subtitle Task",
        "modelDescription": "Pause a running subtitle task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": [
            "taskId"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "write"
        ]
      },
      {
        "name": "subtitleflow_resume_task",
        "displayName": "Resume Subtitle Task",
        "modelDescription": "Resume a paused subtitle task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": [
            "taskId"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "write"
        ]
      },
      {
        "name": "subtitleflow_retry_task",
        "displayName": "Retry Subtitle Task",
        "modelDescription": "Retry a failed subtitle task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": [
            "taskId"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "write"
        ]
      },
      {
        "name": "subtitleflow_delete_task",
        "displayName": "Delete Subtitle Task",
        "modelDescription": "Delete a subtitle task record but keep output files.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            }
          },
          "required": [
            "taskId"
          ]
        },
        "tags": [
          "subtitle",
          "tasks",
          "write"
        ]
      }
    ],
    "configuration": {
      "title": "Subtitle Flow",
      "properties": {
        "subtitleFlow.maxConcurrency": {
          "type": "number",
          "default": 2,
          "description": "Maximum number of parallel transcription tasks."
        },
        "subtitleFlow.targetLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "zh-CN"
          ],
          "description": "List of target languages for translation (BCP-47 codes). 默认为中文。"
        },
        "subtitleFlow.whisperModel": {
          "type": "string",
          "default": "tiny",
          "enum": [
            "tiny",
            "base",
            "small",
            "medium",
            "large",
            "large-v2",
            "large-v3"
          ],
          "description": "Whisper model name (used to locate ggml-<model>.bin)."
        },
        "subtitleFlow.whisperBinary": {
          "type": "string",
          "default": "whisper",
          "description": "Path to the whisper executable (e.g. whisper or /usr/local/bin/whisper)"
        },
        "subtitleFlow.whisperModelPath": {
          "type": "string",
          "default": "",
          "description": "Full path to the whisper model .bin file. If empty, auto-searches common locations."
        },
        "subtitleFlow.whisperLanguage": {
          "type": "string",
          "default": "ja",
          "enum": [
            "auto",
            "ja",
            "zh",
            "en"
          ],
          "description": "Source language spoken in the video. 已简化为默认日语 (ja)。"
        },
        "subtitleFlow.complianceRulesPath": {
          "type": "string",
          "default": "",
          "description": "Path to YAML compliance lexicon file. If empty, uses the built-in default lexicon."
        },
        "subtitleFlow.autoRun": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start processing when videos are added."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "sync:manifest": "node scripts/sync_package_manifest.js",
    "compile": "npm run sync:manifest && npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run sync:manifest && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "pretest": "npm run compile && npm run compile-tests",
    "generate-issue-notes": "node scripts/generate_issue_notes.js --notes issue-notes/20260301-142215-305.md --scan tmp out archives",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm run test:unit",
    "test:unit": "NODE_PATH=./test/runtime node --test out-test/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
